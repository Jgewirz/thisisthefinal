# ── Core AI ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# Default model for all agents (override per-agent below)
OPENAI_MODEL=gpt-4o

# ── Style Agent (The Stylist) ────────────────────────
STYLE_MODEL=gpt-4o              # Chat model
STYLE_TEMPERATURE=0.8           # Higher = more creative
STYLE_MAX_TOKENS=3000           # Response length ceiling
STYLE_VISION_MODEL=gpt-4o      # Image analysis model
STYLE_VISION_TEMPERATURE=0.3   # Lower = more precise analysis

# ── Travel Agent (The Voyager) ───────────────────────
TRAVEL_MODEL=gpt-4o
TRAVEL_TEMPERATURE=0.7
TRAVEL_MAX_TOKENS=2000

# ── Fitness Agent (The Trainer) ──────────────────────
FITNESS_MODEL=gpt-4o
FITNESS_TEMPERATURE=0.7
FITNESS_MAX_TOKENS=2000

# ── Lifestyle Agent (The Curator) ────────────────────
LIFESTYLE_MODEL=gpt-4o
LIFESTYLE_TEMPERATURE=0.7
LIFESTYLE_MAX_TOKENS=2000

# ── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Persistence (optional, enables durable profiles) ─
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# ── Image Processing ────────────────────────────────
MAX_IMAGE_SIZE_MB=7.5

# ── Cloudinary (wardrobe image storage) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
