# ── Core AI ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key
SESSION_SECRET=your_random_32_plus_char_session_secret

# Default model for all agents (override per-agent below)
OPENAI_MODEL=gpt-4o

# ── Style Agent (The Stylist) ────────────────────────
STYLE_MODEL=gpt-4o              # Chat model
STYLE_TEMPERATURE=0.8           # Higher = more creative
STYLE_MAX_TOKENS=3000           # Response length ceiling
STYLE_VISION_MODEL=gpt-4o      # Image analysis model
STYLE_VISION_TEMPERATURE=0.3   # Lower = more precise analysis

# ── Travel Agent (The Voyager) ───────────────────────
TRAVEL_MODEL=gpt-4o
TRAVEL_TEMPERATURE=0.7
TRAVEL_MAX_TOKENS=2000

# ── Fitness Agent (The Trainer) ──────────────────────
FITNESS_MODEL=gpt-4o
FITNESS_TEMPERATURE=0.7
FITNESS_MAX_TOKENS=2000

# ── Lifestyle Agent (The Curator) ────────────────────
LIFESTYLE_MODEL=gpt-4o
LIFESTYLE_TEMPERATURE=0.7
LIFESTYLE_MAX_TOKENS=2000

# ── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Persistence (optional, enables durable profiles) ─
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# ── Image Processing ────────────────────────────────
MAX_IMAGE_SIZE_MB=7.5

# ── Cloudinary (wardrobe image storage) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SerpAPI (real-time Google Flights prices) ────
# Free: 100 searches/month. Paid: $50/mo for 5,000.
# Signup: https://serpapi.com/
SERP_API_KEY=your_serpapi_key

# ── Amadeus (flight/hotel/POI search — fallback) ─
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test

# ── Google Places (rich POI data) ─────────────────
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── Mindbody (fitness class search) ──────────────
MINDBODY_API_KEY=your_api_key_from_developer_portal   # Account → API credentials (NOT the source name)
MINDBODY_SITE_ID=-99                                   # Sandbox site
MINDBODY_SOURCE_NAME=Optaimum                          # Your integration source name
MINDBODY_STAFF_USERNAME=Siteowner                      # Sandbox staff login
MINDBODY_STAFF_PASSWORD=apitest1234                    # Sandbox staff password

# ── Google OAuth (login + calendar) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback
GOOGLE_AUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=                            # openssl rand -hex 32

# ── Booking Agent (browser automation) ─────────────
BOOKING_AGENT_URL=http://localhost:8000
BROWSER_HEADLESS=true
BROWSER_STARTUP_TIMEOUT=90              # Seconds to wait for Chrome to launch (default: 90)
BROWSER_MAX_LAUNCH_RETRIES=2            # Retry count if browser launch times out (default: 2)
FITNESS_BOOKING_TIMEOUT=180             # Total booking flow timeout in seconds (default: 180)
FLIGHT_BOOKING_TIMEOUT=90              # Flight booking flow timeout in seconds (default: 90)
LIFESTYLE_BOOKING_TIMEOUT=300          # Lifestyle booking flow timeout in seconds (default: 300)

# ── HotelBeds (hotel availability + booking) ─────
HOTEL_BEDS_API=your_hotelbeds_api_key
HOTEL_BEDS_SECRET=your_hotelbeds_secret
BROWSER_PROFILES_DIR=./profiles         # Persistent browser profile directory
SESSION_ENCRYPTION_KEY=                 # Fernet key for encrypting auth tokens at rest
                                        # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
